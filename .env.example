# Frontend Configuration
# For local development: API is proxied to Spring Boot backend at localhost:8080 via Vite
# For Vercel production: Set VITE_API_URL to your Spring Boot backend URL (e.g., https://your-backend.com)
VITE_API_URL=/api

# Backend Configuration (set in backend terminal session before `mvn spring-boot:run`)
# DB_URL=jdbc:mysql://localhost:3306/bits_hackathon_hub?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
# DB_USERNAME=root
# DB_PASSWORD=your_mysql_password
# JWT_SECRET=replace_with_strong_secret_in_production

